# Local development only — copy to .env.local (which is gitignored)
# For production, set this in Vercel: Settings -> Environment Variables

CARDTRADER_TOKEN=eyJ...your_token_here...

# Google Cloud Vision API key (for image-based card scanning)
# Get one at: https://console.cloud.google.com/apis/credentials
# Enable the API at: https://console.cloud.google.com/apis/library/vision.googleapis.com
# Free tier: 1000 TEXT_DETECTION calls / month
GOOGLE_VISION_API_KEY=AIza...your_key_here...
