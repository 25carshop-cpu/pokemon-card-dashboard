# Local development only — copy to .env.local (which is gitignored)
# For production, set this in Vercel: Settings -> Environment Variables

CARDTRADER_TOKEN=eyJ...your_token_here...

# eBay Browse API (Watchlist tab — US active listings, free 5000 calls/day)
# Sign up: https://developer.ebay.com  → Create app → Production keyset
EBAY_APP_ID=YourAppID-PRD-xxxxxxx-xxxxxxxx
EBAY_CERT_ID=PRD-xxxxxxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Note: Card scanning uses Tesseract.js in the browser — no API key needed.
